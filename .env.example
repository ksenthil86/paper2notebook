# Paper2Notebook — environment variables
# Copy this file to .env and fill in values (backend reads these at startup)

# Optional: set a default OpenAI API key server-side (users can override in the UI)
OPENAI_API_KEY=

# Optional: GitHub Personal Access Token for creating Gists (users can override in the UI)
GITHUB_TOKEN=

# Backend server settings
HOST=0.0.0.0
PORT=8000
